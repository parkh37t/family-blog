# 로컬 개발용 환경변수 — 이 파일을 `.env` 로 복사한 뒤 값을 채워 넣으세요.
# 프로덕션에서는 호스팅 대시보드(Render 등)에서 동일한 값들을 설정합니다.

# --- 기본 ---
NODE_ENV=development
PORT=3000

# 32자 이상의 무작위 문자열. 터미널에서: openssl rand -hex 32
JWT_SECRET=

# --- Supabase Postgres ---
# Supabase 대시보드 → Project Settings → Database → Connection string → URI
# ⚠️ Transaction pooler(6543) 추천. Session(5432)도 가능.
# 예시: postgresql://postgres.xxxx:PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres
DATABASE_URL=

# --- Supabase Storage (업로드 사진) ---
# Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
# ⚠️ service_role 키를 사용해야 서버가 업로드할 수 있습니다. anon 키로는 안 됩니다.
SUPABASE_SERVICE_KEY=

# 버킷 이름 (기본 "uploads")
SUPABASE_BUCKET=uploads
