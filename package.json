{
  "name": "family-blog",
  "version": "1.0.0",
  "description": "우리 가족을 위한 사진 블로그",
  "main": "server.js",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "node --env-file-if-exists=.env server.js",
    "dev": "node --env-file-if-exists=.env --watch server.js",
    "seed": "node --env-file-if-exists=.env seed.js",
    "start:prod": "node seed.js && node server.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.3",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "pg": "^8.20.0"
  }
}
